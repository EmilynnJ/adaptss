# ============ SoulSeer Environment ============
# Copy to .env (server) and provide real values. Never commit .env.

# --- App ---
NODE_ENV=development
PORT=8080
CLIENT_ORIGIN=http://localhost:5173

# --- Neon (Postgres) ---
NEON_DB_CONNECTION_STRING=
NEON_DB_PGHOST=
NEON_DB_PGDATABASE=
NEON_DB_PGUSER=
NEON_DB_PGPASSWORD=
NEON_DB_PGSSLMODE=require
NEON_DB_PGCHANNELBINDING=require
NEON_API_KEY=

# --- Redis (active session billing state) ---
REDIS_DB_HOST=
REDIS_DB_PORT=
REDIS_DB_USERNAME=
REDIS_DB_PASSWORD=
REDIS_DB_ENDPOINT=

# --- Auth0 (server side) ---
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_APP_ID=
AUTH0_CLIENT_SECRET=
# Auth0 Management API (for admin-created reader accounts)
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=

# --- Agora ---
AGORA_APP_ID=
VITE_AGORA_APP_ID=
AGORA_SECURITY_CERTIFICATE=
AGORA_CHAT_APP_ID=
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# --- Cloudinary (reader profile images) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET=

# --- Backblaze B2 (S3-compatible fallback storage) ---
BACKBLAZE_APP_ID=
BACKBLAZE_KEY_NAME=
BACKBLAZE_APP_KEY=
BACKBLAZE_BUCKET=
BACKBLAZE_ENDPOINT=

# --- Community links ---
VITE_DISCORD_INVITE_URL=https://discord.gg/soulseer
VITE_FACEBOOK_GROUP_URL=https://facebook.com/groups/soulseer

# --- Client (Vite) Auth0 ---
VITE_AUTH0_DOMAIN_URL=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
VITE_AUTH0_REDIRECT_URI=http://localhost:5173/dashboard
VITE_API_BASE_URL=http://localhost:8080
